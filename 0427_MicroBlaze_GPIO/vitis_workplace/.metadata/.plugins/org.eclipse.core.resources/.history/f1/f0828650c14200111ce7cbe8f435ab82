#include "UPCounter.h"

uint16_t counter = 0;

void UPCounter_Init() {
	FND_Init();
	counter = 0;
}
void UPCounter_Excute() {
	static uint32_t prevTimeCounter = 0;
	FND_Digit();

	if(millis() - prevTimeCounter < 100 - 1) {
		//0.1s 간격으로 증가
		//100 보다 작으면 밑으로 안내려감
		return;
	}
		prevTimeCounter = millis();
		FND_SetNum(counter++);


}
