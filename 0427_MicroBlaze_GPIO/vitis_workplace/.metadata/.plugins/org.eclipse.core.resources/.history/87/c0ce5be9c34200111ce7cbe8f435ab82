#include "UPCounter.h"

uint16_t counter = 0;

void UPCounter_Init() {
	FND_Init();
	counter = 0;
}
void UPCounter_Excute() {

	UPCounter_DispLoop();

	if(Button_GetState() == PUSHED) {
		uint8_t UPCounterState = 0;
		if (UPCounterState) {
			UPCounter_Run();
			UPCounterState = 1;
		}
		else {

		UPCounter_Stop();
		}
	}
}

void UPCounter_DispLoop() {
	FND_Digit();
}

void UPCounter_Run() {
	static uint32_t prevTimeCounter = 0;


		if(millis() - prevTimeCounter < 100 - 1) {
			//0.1s 간격으로 증가
			//100 보다 작으면 밑으로 안내려감
			return;
		}
		prevTimeCounter = millis();

		FND_SetNum(counter++);
}

void UPCounter_Stop() {
		FND_SetNum(counter);
}
