#include "UPCounter.h"

uint16_t counter = 0;

void UPCounter_Init() {
	FND_Init();
}
void UPCounter_Excute() {
	static uint32_t prevTimeCounter = 0;

	if(millis() - prevTimeCounter < 100) {
		//0.1s 除問戲煎 隸陛
		return;
	}
		prevTimeCounter = millis();
		FND_SetNum(counter++);

		FND_Digit();

}
