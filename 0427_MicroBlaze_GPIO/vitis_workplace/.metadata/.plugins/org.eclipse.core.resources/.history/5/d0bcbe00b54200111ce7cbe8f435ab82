#include "ap_main.h"
#include "../driver/FND/FND.h"
#include "../common/common.h"


void ap_init() {
	FND_Init();
}

void ap_excute() {
	uint16_t counter = 0;
	//FND_SetNum(1234);
	//uint32_t prevTimeDisp = 0;
	uint32_t prevTimeCounter = 0;

	while(1)
	{
		if(millis() - prevTimeCounter >= 100) {
			//0.1s 除問戲煎 隸陛
			prevTimeCounter = millis();
			FND_SetNum(counter++);
		}

		FND_Digit();
		delay_ms(1);
		millis_inc();
	}
}
