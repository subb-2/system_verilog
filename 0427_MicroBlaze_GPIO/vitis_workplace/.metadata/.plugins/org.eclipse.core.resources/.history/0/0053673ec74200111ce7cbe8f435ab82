#include "UPCounter.h"

typedef enum {
	RELEASED = 0, //누르지 않았을 때
	PUSHED,
	NO_ACT
}button_state_t;

void Button_Init() {
	GPIO_SetMode (GPIOA, GPIO_PIN_4|GPIO_PIN_5|GPIO_PIN_6|GPIO_PIN_7, INPUT);
}

button_state_t Button_GetState() {
	static button_state_t prevState = RELEASED;
	button_state_t curState = GPIO_ReadPin(GPIOA, GPIO_PIN_4);
	if (prevState == RELEASED && curState == PUSHED){
		delay_ms(5);
		prevState = PUSHED;
		return PUSHED;
	} else if (prevState == PUSHED && curState == RELEASED) {
		prevState = RELEASED;
		return RELEASED;
	}
	return NO_ACT;
}

uint16_t counter = 0;

void UPCounter_Init() {
	FND_Init();
	Button_Init();
	counter = 0;
}
void UPCounter_Excute() {

	UPCounter_DispLoop();

	if(Button_GetState() == PUSHED) {
		static uint8_t UPCounterState = 0;
		if (UPCounterState) {
			UPCounter_Run();
			UPCounterState = 0;
		}
		else {

		UPCounter_Stop();
		UPCounterState = 1;
		}
	}
}

void UPCounter_DispLoop() {
	FND_Digit();
}

void UPCounter_Run() {
	static uint32_t prevTimeCounter = 0;


		if(millis() - prevTimeCounter < 100 - 1) {
			//0.1s 간격으로 증가
			//100 보다 작으면 밑으로 안내려감
			return;
		}
		prevTimeCounter = millis();

		FND_SetNum(counter++);
}

void UPCounter_Stop() {
		FND_SetNum(counter);
}
