#include "UPCounter.h"

// 1. 상태 머신용 상태 열거형 (에러 났던 부분 수정)
typedef enum {
    STOP,
    RUN,
    CLEAR
} upcounter_state_t;

// 2. 버튼 상태 열거형
typedef enum {
    RELEASED = 0, // 누르지 않았을 때
    PUSHED,
    NO_ACT
} button_state_t;

// 전역 변수
uint16_t counter = 0;
static upcounter_state_t upCounterState = STOP; // 현재 상태 저장 변수 추가

void Button_Init() {
    GPIO_SetMode(GPIOA, GPIO_PIN_4|GPIO_PIN_5|GPIO_PIN_6|GPIO_PIN_7, INPUT);
}

// 3. 버튼 1 (PIN 4)
button_state_t Button_GetState() {
    static button_state_t prevState = RELEASED;
    button_state_t curState = GPIO_ReadPin(GPIOA, GPIO_PIN_4);

    if (prevState == RELEASED && curState == PUSHED){
        delay_ms(5);
        prevState = PUSHED;
        return PUSHED;
    } else if (prevState == PUSHED && curState == RELEASED) {
        delay_ms(5); // 누락되었던 딜레이 추가
        prevState = RELEASED;
        return RELEASED;
    }
    return NO_ACT;
}

// 4. 버튼 2 (PIN 7) - 누락되었던 함수 추가
button_state_t Button2_GetState() {
    static button_state_t prevState = RELEASED;
    button_state_t curState = GPIO_ReadPin(GPIOA, GPIO_PIN_7);

    if (prevState == RELEASED && curState == PUSHED){
        delay_ms(5);
        prevState = PUSHED;
        return PUSHED;
    } else if (prevState == PUSHED && curState == RELEASED) {
        delay_ms(5);
        prevState = RELEASED;
        return RELEASED;
    }
    return NO_ACT;
}

void UPCounter_Init() {
    FND_Init();
    Button_Init();
    counter = 0;
}

void UPCounter_Excute() {
    switch (upCounterState)
    {
    case STOP:
        UpCounter_Stop();
        if (Button_GetState() == PUSHED) {
            upCounterState = RUN;
        }
        else if (Button2_GetState() == PUSHED) {
            upCounterState = CLEAR;
        }
        break;

    case RUN:
        UpCounter_Run();
        if (Button_GetState() == PUSHED) {
            upCounterState = STOP;
        }
        break;

    case CLEAR:
        UpCounter_Clear();
        upCounterState = STOP;
        break;

    default:
        UpCounter_Stop();
        break;
    }
}

void UPCounter_DispLoop() {
    FND_Digit();
}

void UPCounter_Run() {
    static uint32_t prevTimeCounter = 0;

    if(millis() - prevTimeCounter < 100 - 1) {
        return;
    }
    prevTimeCounter = millis();
    FND_SetNum(counter++);
}

void UPCounter_Stop() {
    FND_SetNum(counter);
}

// 누락되었던 Clear 함수 추가
void UpCounter_Clear() {
    counter = 0;
    FND_SetNum(counter);
}
