#include "UpCounter.h"
#include "sleep.h"

typedef enum{
   STOP,
   RUN,
   CLEAR
}upcounter_state_t;

typedef enum {
   RELEASED = 0,
   PUSHED
}button_state_t;

typedef enum {
	NO_ACT = 0,
   ACT_RELEASED,
   ACT_PUSHED
}button_act_t;

typedef struct {
	GPIO_Typedef_t *GPIOx;
	uint32_t GPIO_Pin;
	button_state_t prevState;
}hBtn_t;


hBtn_t hBtnRunStop, hBtnClear;
uint16_t counter = 0;

void Button_Init(hBtn_t*hbtn, GPIO_Typedef_t *GPIOx, uint32_t GPIO_Pin)
{
	// 받아온 핀만 골라서 INPUT으로 설정합니다.
	    GPIO_SetMode(GPIOx, GPIO_Pin, INPUT);

	    // 하드코딩을 지우고, 넘겨받은 구조체 포인터(hbtn)에 직접 값을 세팅합니다.
	    hbtn->GPIOx = GPIOx;
	    hbtn->GPIO_Pin = GPIO_Pin;
	    hbtn->prevState = RELEASED;

}

button_act_t Button_GetState(hBtn_t *hbtn)
{
   //static button_state_t prevState = RELEASED;
   button_state_t curState = GPIO_ReadPin(hbtn->GPIOx, hbtn->GPIO_Pin);
   if(hbtn->prevState == RELEASED && curState == PUSHED){
      delay_ms(5);
      hbtn->prevState = PUSHED;
      return ACT_PUSHED;
   }
   else if (hbtn->prevState == PUSHED && curState == RELEASED){
      delay_ms(5);
      hbtn->prevState = RELEASED;
      return ACT_RELEASED;
   }
   return NO_ACT;
}


void UpCounter_Init()
{
   FND_Init();
   Button_Init(&hBtnRunStop, GPIOA, GPIO_PIN_4);
   Button_Init(&hBtnClear, GPIOA, GPIO_PIN_7);
   counter = 0;
}

void UpCounter_Excute()
{
    UpCounter_DispLoop();
     static upcounter_state_t upCounterState = STOP;

     switch (upCounterState)
       {
       case STOP:
          UpCounter_Stop();
          if(Button_GetState(&hBtnRunStop) == ACT_PUSHED){
             upCounterState = RUN;
          }else if(Button_GetState(&hBtnClear) == ACT_PUSHED){
                 upCounterState = CLEAR;}

         break;
       case RUN:
          UpCounter_Run();
          if(Button_GetState(&hBtnRunStop) == ACT_PUSHED){
             upCounterState = STOP;
          }
          break;
       case CLEAR:
          UpCounter_Clear();
          upCounterState = STOP;
          break;
       default:
          UpCounter_Stop();
          break;
       }

}

void UpCounter_DispLoop()
{
   FND_Digit();
}

void UpCounter_Run()
{
   static uint32_t prevTimeCounter = 0;
   if(millis() - prevTimeCounter < 100-1)
            {
               return;
   }
   prevTimeCounter = millis();
   FND_SetNum(counter++);
}

void UpCounter_Stop()
{
   FND_SetNum(counter);
}

void UpCounter_Clear()
{
   counter = 0;
   FND_SetNum(counter);
}

